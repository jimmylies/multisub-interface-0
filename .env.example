# WalletConnect Project ID (get from https://cloud.walletconnect.com/)
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Network Configuration
VITE_NETWORK=base-sepolia  # Supported: "sepolia", "mainnet", "base", "base-sepolia"

# ─── RPC pool (Base + Base Sepolia) ──────────────────────────────────────────
# The wagmi transport for Base routes through a multi-RPC pool:
#   - Primary endpoint (Alchemy free tier recommended) handles all writes and
#     fee/nonce reads. Other reads round-robin across the primary + public pool.
#   - The pool filters out any endpoint that is >4 blocks stale vs the leader.
# Get an Alchemy app key at https://dashboard.alchemy.com/apps and DOMAIN-LOCK
# it under "Setup → Allowed Origins" — the URL ends up in the JS bundle.
VITE_RPC_URL_BASE_PRIMARY=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
VITE_RPC_URL_BASE_SEPOLIA_PRIMARY=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Optional pipe-separated extra fallback URLs appended to the curated public
# pool (see src/lib/rpcPool.ts for the defaults).
# VITE_RPC_URL_BASE_FALLBACKS=https://your.custom/rpc|https://another/rpc
# VITE_RPC_URL_BASE_SEPOLIA_FALLBACKS=

# Subgraph Configuration
VITE_SUBGRAPH_URL=https://api.studio.thegraph.com/query/<id>/<name>/version/latest
VITE_SUBGRAPH_AUTH_TOKEN=your_token_here

VITE_AGENT_VAULT_FACTORY_ADDRESS=0x
VITE_ORACLE_ADDRESS=0x
